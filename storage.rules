rules_version = '2';

// Craft rules based on the specific structures for your project.
service firebase.storage {
  match /b/{bucket}/o {
    
    // Strict Admin check via Auth token email
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'compscientofficial@gmail.com';
    }

    // Authenticated users can read courses (enforced by DB access logically)
    match /course_videos/{videoFile} {
      allow read: if request.auth != null; 
      allow write: if isAdmin() &&
                   request.resource.size < 50_000_000 && // 50MB max video limit
                   request.resource.contentType.matches('video/.*'); // Strict content type validation
    }
    match /course_photos/{photoFile} {
      allow read: if request.auth != null; 
      allow write: if isAdmin() &&
                   request.resource.size < 5_000_000 && // 5MB max photo limit
                   request.resource.contentType.matches('image/.*'); // Strict content type validation
    }

    // Default DENY EVERYTHING else that is not explicitly defined above
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
