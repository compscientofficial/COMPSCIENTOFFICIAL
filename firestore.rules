rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Dynamic Admin Check: Is official email OR has 'admin' role in DB
    function isAdmin() {
      return request.auth != null && 
             (
               ('email' in request.auth.token && request.auth.token.email == 'compscientofficial@gmail.com') ||
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
             );
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // CMS & Website Configuration
    // Strict schema validation applied here for security against injection
    match /content/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /courses/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /website_config/{document=**} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Logging & History
    match /login_errors/{document=**} {
      // Anyone can post an error log, but they cannot read them or delete them unless Admin
      allow create: if true; 
      allow read, update, delete: if isAdmin(); 
    }
    match /login_history/{document=**} {
      allow create: if request.auth != null; 
      allow read, update, delete: if isAdmin();
    }

    // User Management API
    match /users/{userId} {
      allow list: if isAdmin();
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) 
                    && (request.resource.data.role == 'student' || isAdmin());
                    
      allow update: if isOwner(userId) 
                    && (request.resource.data.role == resource.data.role || isAdmin()); 
      
      allow delete: if isAdmin(); 
    }

    // Course Registrations
    match /users_courses_pending/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }
    
    // Legacy Registrations Support
    match /registrations/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }
  }
}
